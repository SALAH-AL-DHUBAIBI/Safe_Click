# Flutter Environment Configuration
# Copy this file to .env and customize for your deployment.
# The file is loaded by flutter_dotenv at startup.

# ── Backend API ───────────────────────────────────────────────────────────────
# Development (Android Emulator):
# API_BASE_URL=http://10.0.2.2:8000/api
# Development (physical device on LAN — replace with your machine's LAN IP):
API_BASE_URL=http://192.168.1.102:8000/api
# Production:
# API_BASE_URL=https://api.safeclick.yourdomain.com/api

# ── App Identity (Phase 6 — App-ID Header) ───────────────────────────────────
APP_ID=safeclick-flutter-client
# APP_SECRET must match the APP_SECRET in Django's settings.py
# Leave empty in dev — middleware skips signature check in DEBUG mode.
APP_SECRET=
